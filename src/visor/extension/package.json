{
  "name": "visor-hud",
  "displayName": "V.I.S.O.R. HUD",
  "description": "Visual Intelligence System for Orchestrated Reasoning - WebGPU Developer HUD",
  "version": "0.6.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/example/visor"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "visor.startHUD",
        "title": "Start V.I.S.O.R. HUD"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "visor-explorer",
          "title": "V.I.S.O.R.",
          "icon": "assets/visor-icon.svg"
        }
      ]
    },
    "views": {
      "visor-explorer": [
        {
          "type": "webview",
          "id": "visor-sidebar",
          "name": "Telemetry"
        }
      ]
    },
    "configuration": {
      "title": "V.I.S.O.R. Config",
      "properties": {
        "visor.localProxyPort": {
          "type": "number",
          "default": 4173,
          "description": "Local Vite Dev Server Port"
        },
        "visor.remoteProxyPort": {
          "type": "number",
          "default": 8080,
          "description": "Remote SSH Docker Proxy Port"
        },
        "visor.enableLocalForwarding": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic reverse-tunnel over SSH for Docker HUD"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
